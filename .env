# ── Reddit API ─────────────────────────────────────────────────────────────
# Get these at: https://www.reddit.com/prefs/apps → "create another app"
# Choose type: "script"
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=SentimentEngine/0.1 by YourRedditUsername

# ── Twitter/X API (optional for Phase 1a) ──────────────────────────────────
# Get at: https://developer.twitter.com/en/portal/dashboard
# Free tier gives you ~500k tweets/month, 7-day lookback
TWITTER_BEARER_TOKEN=your_bearer_token_here
